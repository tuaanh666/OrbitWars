# MẪU biến môi trường — copy thành .env rồi điền giá trị thật
#   cp .env.example .env
# (.env KHÔNG được commit vì chứa mật khẩu/khóa API)

# Kafka 
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC_RATINGS=ratings-stream
KAFKA_TOPIC_RECS=recommendations
# Tốc độ phát luồng rating (events/giây) để minh hoạ real-time
STREAM_RATE_PER_SEC=200

# HDFS 
HDFS_NAMENODE=hdfs://namenode:9000
HDFS_DATA_DIR=/data/movielens

# Spark
SPARK_MASTER=spark://spark-master:7077

# HBase
HBASE_HOST=hbase
HBASE_THRIFT_PORT=9090
HBASE_TABLE_RECS=user_recommendations

#  MySQL (ĐỔI mật khẩu khi chạy thật) 
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=movielens
MYSQL_USER=mluser
MYSQL_PASSWORD=CHANGE_ME
MYSQL_ROOT_PASSWORD=CHANGE_ME

# --- Flask ---
FLASK_PORT=5000

# --- TMDB (lấy poster phim) — đăng ký miễn phí tại themoviedb.org ---
TMDB_API_KEY=YOUR_TMDB_API_KEY
